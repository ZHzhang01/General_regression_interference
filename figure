library(ggplot2)

# 创建示例数据集
data <- data.frame(direct = c("HT", "Haj", "F", ("L"), "ND-F", "ND-G_1", "ND-L",  "ND-G_2"),
                   Interval = midpoints,
                   lower_ci = lower_bounds,
                   upper_ci = upper_bounds)

# 将 Method 列转换为有序因子，并指定固定顺序
datadirect<−factor(datadirect <- factor(datadirect, levels = c("HT", "Haj", "F", ("L"), "ND-F", "ND-G_1", "ND-L",  "ND-G_2"), ordered = TRUE)

# 绘制带有置信区间的散点图，并设置不同柱子颜色
p1 <- ggplot(data, aes(x = direct, y = Interval, color = direct)) +
  geom_point(size = 4, shape = 3) +  # 实心圆点
  
  geom_errorbar(data = subset(data, direct %in% c("HT", "Haj", "F", "L")),
                aes(ymin = lower_ci, ymax = upper_ci),
                width = 0.5, size = 1, linetype = "longdash")+
  geom_errorbar(data = subset(data, direct %in% c("ND-F", "ND-G_1", "ND-L", "ND-G_2")),
                aes(ymin = lower_ci, ymax = upper_ci),
                width = 0.5, size = 1, linetype = "solid")+
  theme(axis.text.x = element_text(angle = 90, hjust = 1), aspect.ratio = 2/2) +  # 使横坐标竖直显示
  scale_color_manual(values = c("black", "black", "brown", "blue", "brown", "brown", "blue", "blue"))+
  geom_hline(yintercept = 0, linetype = "dashed", color = "black")+
  theme(legend.position = "none") 






