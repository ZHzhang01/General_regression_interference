tauhat <- c(0.00820, 0.0146, 0.0170, 0.0168, 0.0167, 0.0161 ,0.0164, 0.0175)

se <- c(0.0272, 0.0225, 0.0218, 0.0197, 0.0211, 0.0204, 0.0195, 0.0193)




lower_bounds <- tauhat - 1.96 * se
